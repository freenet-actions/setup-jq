{
  "name": "setup-jq",
  "version": "3.3.3",
  "private": true,
  "description": "TypeScript template action",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build",
    "test": "jest",
    "all": "npm run build && npm run format && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freenet-actions/setup-jq.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "1.11.1",
    "@actions/tool-cache": "2.0.2"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.33",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vercel/ncc": "0.38.4",
    "eslint": "9.39.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-jest": "29.15.2",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "jest-circus": "30.3.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3"
  }
}
